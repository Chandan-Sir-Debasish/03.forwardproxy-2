				{
					"name": "Allowed Substring Domain - myfacebook.com",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is not 403 Forbidden\", function () {",
									"    pm.expect(pm.response.code).to.not.equal(403);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "myfacebook.com",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://{{proxyHost}}:8889/",
							"protocol": "http",
							"host": [
								"{{proxyHost}}"
							],
							"port": "8889",
							"path": [
								""
							]
						},
						"description": "Sends a request targeting myfacebook.com. The proxy should NOT block it with a 403, demonstrating that boundary-safe regex patterns are working correctly."
