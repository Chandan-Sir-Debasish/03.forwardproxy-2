		{
			"name": "Port 8889 - Boundary and Case Sensitivity Tests",
			"item": [
				{
					"name": "Case-Insensitive Blocking - FACEBOOK.COM",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 403 Forbidden\", function () {",
									"    pm.response.to.have.status(403);",
									"});",
									"pm.test(\"Body contains social media block message\", function () {",
									"    pm.expect(pm.response.text()).to.include(\"Access to social media is blocked by company policy\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "FACEBOOK.COM",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://{{proxyHost}}:8889/",
							"protocol": "http",
							"host": [
								"{{proxyHost}}"
							],
							"port": "8889",
							"path": [
								""
							]
						},
						"description": "Tests case-insensitivity (~* rule). FACEBOOK.COM should be blocked just like facebook.com."
					},
					"response": []
				},
				{
					"name": "Allowed Substring Domain - myfacebook.com",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is not 403 Forbidden\", function () {",
									"    pm.expect(pm.response.code).to.not.equal(403);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "myfacebook.com",
