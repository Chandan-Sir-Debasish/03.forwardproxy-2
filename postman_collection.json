								"exec": [
									"pm.test(\"Status code is 403 Forbidden\", function () {",
									"    pm.response.to.have.status(403);",
									"});",
									"pm.test(\"Body contains video streaming block message\", function () {",
									"    pm.expect(pm.response.text()).to.include(\"Video streaming is blocked during work hours\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "netflix.com",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://{{proxyHost}}:8889/",
							"protocol": "http",
							"host": [
								"{{proxyHost}}"
							],
							"port": "8889",
							"path": [
								""
