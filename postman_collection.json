		{
			"name": "Port 8889 - Protocol Forwarding and Payload Tests",
			"item": [
				{
					"name": "Query Parameter Preservation",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Query parameters are preserved in upstream request\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.args.testParam).to.equal(\"active\");",
									"    pm.expect(jsonData.args.user).to.equal(\"teacher\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "httpbin.org",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://{{proxyHost}}:8889/get?testParam=active&user=teacher",
							"protocol": "http",
							"host": [
								"{{proxyHost}}"
							],
							"port": "8889",
							"path": [
								"get"
							],
							"query": [
								{
									"key": "testParam",
									"value": "active"
								},
								{
									"key": "user",
									"value": "teacher"
								}
							]
						},
						"description": "Tests that query strings are forwarded transparently by the proxy to httpbin.org/get."
					},
					"response": []
				},
				{
					"name": "Request Header Forwarding",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Custom header is forwarded to upstream\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.headers['X-Academic-Institution']).to.equal(\"DevOps-Lab-University\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "httpbin.org",
								"type": "text"
							},
							{
								"key": "X-Academic-Institution",
								"value": "DevOps-Lab-University",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://{{proxyHost}}:8889/headers",
							"protocol": "http",
							"host": [
								"{{proxyHost}}"
							],
							"port": "8889",
							"path": [
								"headers"
							]
						},
						"description": "Tests that custom HTTP headers are transparently forwarded to the destination server."
					},
					"response": []
				},
				{
					"name": "POST Request Body Payload Forwarding",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"POST payload is preserved and returned\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.json.testKey).to.equal(\"testValue\");",
									"    pm.expect(jsonData.json.valid).to.equal(true);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Host",
								"value": "httpbin.org",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"testKey\": \"testValue\",\n    \"valid\": true\n}"
						},
						"url": {
							"raw": "http://{{proxyHost}}:8889/post",
							"protocol": "http",
							"host": [
								"{{proxyHost}}"
							],
							"port": "8889",
							"path": [
								"post"
							]
						},
						"description": "Tests that HTTP POST request bodies are forwarded intact to the upstream server."
					},
					"response": []
				}
			]
		}
	]
}
