{
	"info": {
		"_postman_id": "9a38f321-df10-410a-81a2-cb3918a5bc79",
		"name": "Nginx Forward Proxy Extended Tests",
		"description": "Extended Postman collection to test Nginx Forward Proxy functionality: access controls, content filtering, query parameter routing, header forwarding, and HTTP POST body handling.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Port 8888 - Access Control",
			"item": [
				{
					"name": "ACL Blocked - Unauthorized Request from Host",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 403 Forbidden\", function () {",
									"    pm.response.to.have.status(403);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "example.com",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://{{proxyHost}}:8888/",
							"protocol": "http",
							"host": [
								"{{proxyHost}}"
							],
							"port": "8888",
							"path": [
								""
							]
						},
						"description": "Sends a request to port 8888 representing a target host. Since the host machine's IP is not in Nginx's allow list, the proxy should return a 403 Forbidden."
					},
					"response": []
				}
			]
		},
